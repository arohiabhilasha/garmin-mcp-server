{
  "name": "garmin-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "garmin-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "auth": "tsx src/auth.ts",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "latest",
    "open": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
